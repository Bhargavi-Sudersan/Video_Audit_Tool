# ---- Storage backend: "demo" (no creds) or "google" ----
STORAGE_BACKEND=demo

# ---- Demo / local paths ----
DEMO_VIDEO_DIR=./data/videos
LOCAL_STORE_FILE=./data/reviews.json
FRAME_CACHE_DIR=./data/frame_cache

# ---- Google integration (required when STORAGE_BACKEND=google) ----
# Service-account JSON key path; leave blank to use Application Default Creds.
GOOGLE_CREDENTIALS_FILE=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_REVIEWS_TAB=Reviews

# ---- AI (Claude vision). Leave key blank to run heuristic-only mode. ----
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_FRAMES=8
ENABLE_AI=true

# ---- Analysis tuning ----
TARGET_SAMPLES=60

# ---- CORS (frontend origins) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
